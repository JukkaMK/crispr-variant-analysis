import numpy as np
import pandas as pd

# df = pd.read_csv("data/variants_demo.tsv", sep="\t")

# 1) Peruspiste varianttiluokasta
impact_base = {
    "stop_gained": 8,
    "frameshift_variant": 8,
    "splice_acceptor_variant": 8,
    "splice_donor_variant": 8,
    "missense_variant": 4,
    "inframe_insertion": 4,
    "inframe_deletion": 4,
    "synonymous_variant": 1,
    "intron_variant": 1,
    "intergenic_variant": 0,
}

def score_variant(row):
    score = 0.0

    # Consequence / variant_class
    cons = str(row.get("consequence", "")).strip()
    score += impact_base.get(cons, 2)  # oletus 2 jos tuntematon

    # 2) Harvinaisuus (AF)
  
    af = row.get("af", np.nan)
    if pd.isna(af):
        score += 2.0  # ei löytynyt populaatiosta → kiinnostava (varovainen bonus)
    else:
        # logiikka: harvinainen = bonus, yleinen = miinus
        # 1e-4 ~ erittäin harvinainen
        if af < 1e-4:
            score += 2.0
        elif af < 1e-3:
            score += 1.0
        elif af < 1e-2:
            score += 0.0
        else:
            score -= 2.0  # melko yleinen

    # 3) Ennusteet (jos löytyy)
    cadd = row.get("cadd", np.nan)
    if not pd.isna(cadd):
        # karkea: CADD > 20 usein "potentiaalisesti haitallinen"
        score += 1.0 if cadd >= 20 else 0.0

    spliceai = row.get("spliceai", np.nan)
    if not pd.isna(spliceai):
        score += 1.5 if spliceai >= 0.5 else 0.0

    return score

